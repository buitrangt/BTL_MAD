<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F6F6"
    android:orientation="vertical"
    android:paddingStart="12dp"
    android:paddingTop="8dp"
    android:paddingEnd="12dp"
    tools:context=".fragments.HistoryFragment">

    <!-- Search Bar with Calendar and Reset Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="6dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Search Input -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_search_rounded"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@android:drawable/ic_menu_search"
                app:tint="#A8A8A8" />

            <EditText
                android:id="@+id/etSearchTransaction"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Tìm kiếm giao dịch..."
                android:textColor="#222222"
                android:textColorHint="#B2B2B2"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Calendar/Clear Date Button (Dynamic Icon) -->
        <ImageButton
            android:id="@+id/btnDatePicker"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:src="@android:drawable/ic_menu_my_calendar"
            android:background="@drawable/bg_search_rounded"
            android:scaleType="centerInside"
            android:contentDescription="Chọn ngày"
            app:tint="@color/primary_green" />

    </LinearLayout>

    <!-- Summary Cards (Horizontal Scroll) -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Expense Card -->
            <LinearLayout
                android:layout_width="150dp"
                android:layout_height="108dp"
                android:background="@drawable/bg_card_green"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chi tiêu"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvMonthLabelExpense"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tháng này"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvMonthExpense"
                    android:layout_width="126dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="0 đ"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:maxLines="2"
                    android:ellipsize="end" />
            </LinearLayout>

            <!-- Income Card -->
            <LinearLayout
                android:layout_width="150dp"
                android:layout_height="108dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_card_white"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thu nhập"
                        android:textColor="#8D8D8D"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvMonthLabelIncome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tháng này"
                        android:textColor="#8D8D8D"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvMonthIncome"
                    android:layout_width="126dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="0 đ"
                    android:textColor="#222222"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:maxLines="2"
                    android:ellipsize="end" />
            </LinearLayout>

            <!-- Savings Card -->
            <LinearLayout
                android:layout_width="150dp"
                android:layout_height="108dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_card_white"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tiết kiệm"
                        android:textColor="#8D8D8D"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvMonthLabelSavings"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tháng này"
                        android:textColor="#8D8D8D"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvMonthSavings"
                    android:layout_width="126dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="0 đ"
                    android:textColor="#18C58F"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:maxLines="2"
                    android:ellipsize="end" />
            </LinearLayout>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Transaction History List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvHistory"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="12dp" />

</LinearLayout>