<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F4F8"
    android:orientation="vertical"
    android:paddingHorizontal="20dp"
    android:paddingTop="16dp"
    tools:context=".fragments.HistoryFragment">

    <!-- ============ HEADER TITLE ============ -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/montserrat_bold"
        android:text="Lịch sử giao dịch"
        android:textColor="#1A2235"
        android:textSize="22sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:fontFamily="@font/montserrat_regular"
        android:text="Theo dõi các khoản chi và thu của bạn"
        android:textColor="#8E96A3"
        android:textSize="12sp" />

    <!-- ============ SEARCH BAR + DATE PICKER ============ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="14dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/bg_search_modern"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_search"
                app:tint="#8E96A3" />

            <EditText
                android:id="@+id/etSearchTransaction"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@null"
                android:fontFamily="@font/montserrat_regular"
                android:hint="Tìm kiếm giao dịch..."
                android:textColor="#1A2235"
                android:textColorHint="#B2B8C2"
                android:textSize="13sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnDatePicker"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_search_modern"
            android:contentDescription="Chọn ngày"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_menu_my_calendar"
            app:tint="#10B981" />
    </LinearLayout>

    <!-- ============ FILTER CARDS (3 equal columns) ============ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:weightSum="3">

        <!-- ===== EXPENSE CARD (default selected) ===== -->
        <LinearLayout
            android:id="@+id/cardExpense"
            android:layout_width="0dp"
            android:layout_height="118dp"
            android:layout_weight="1"
            android:background="@drawable/bg_card_filter_selected"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical"
            android:padding="12dp">

            <FrameLayout
                android:id="@+id/iconExpenseWrap"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:background="@drawable/bg_icon_circle_white">

                <ImageView
                    android:id="@+id/iconExpense"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_input_delete"
                    app:tint="#FFFFFF" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvCardExpenseTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/montserrat_bold"
                android:text="Chi tiêu"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvMonthLabelExpense"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_regular"
                android:text="Tháng này"
                android:textColor="#FFFFFF"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/tvMonthExpense"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:fontFamily="@font/montserrat_bold"
                android:maxLines="1"
                android:text="0đ"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- ===== INCOME CARD ===== -->
        <LinearLayout
            android:id="@+id/cardIncome"
            android:layout_width="0dp"
            android:layout_height="118dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_card_filter_unselected"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical"
            android:padding="12dp">

            <FrameLayout
                android:id="@+id/iconIncomeWrap"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:background="@drawable/bg_icon_circle_green">

                <ImageView
                    android:id="@+id/iconIncome"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_input_add"
                    app:tint="#10B981" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvCardIncomeTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/montserrat_bold"
                android:text="Thu nhập"
                android:textColor="#1A2235"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvMonthLabelIncome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_regular"
                android:text="Tháng này"
                android:textColor="#8E96A3"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/tvMonthIncome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:fontFamily="@font/montserrat_bold"
                android:maxLines="1"
                android:text="0đ"
                android:textColor="#1A2235"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- ===== SAVINGS CARD ===== -->
        <LinearLayout
            android:id="@+id/cardSavings"
            android:layout_width="0dp"
            android:layout_height="118dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_card_filter_unselected"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical"
            android:padding="12dp">

            <FrameLayout
                android:id="@+id/iconSavingsWrap"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:background="@drawable/bg_icon_circle_blue">

                <ImageView
                    android:id="@+id/iconSavings"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_menu_save"
                    app:tint="#1976D2" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvCardSavingsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/montserrat_bold"
                android:text="Tiết kiệm"
                android:textColor="#1A2235"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvMonthLabelSavings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_regular"
                android:text="Tháng này"
                android:textColor="#8E96A3"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/tvMonthSavings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:fontFamily="@font/montserrat_bold"
                android:maxLines="1"
                android:text="0đ"
                android:textColor="#18C58F"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- ============ TRANSACTION LIST ============ -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="18dp"
        android:layout_weight="1"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp">

        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeRefreshLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvHistory"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingTop="6dp"
                android:paddingBottom="110dp" />

        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>
