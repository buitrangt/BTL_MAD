<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F4F8"
    tools:context=".MainActivity">

    <!-- HEADER -->
    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_marginHorizontal="22dp"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/header_txt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/montserrat_bold"
            android:text="Home"
            android:textColor="#1A2235"
            android:textSize="30sp" />

        <ImageView
            android:id="@+id/settings"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@drawable/settings"
            app:tint="#7F8795" />

    </RelativeLayout>

    <!-- CONTAINER -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/pager"
        android:layout_below="@id/header"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- DOCK -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#FFFFFF">

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tab_layout"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="#FFFFFF"
                app:tabIconTint="#A8AFBA"
                app:tabIndicatorColor="#13B67A"
                app:tabIndicatorHeight="3dp"
                app:tabRippleColor="#1A13B67A"
                app:tabSelectedTextColor="#13B67A"
                app:tabTextColor="#A8AFBA"
                app:tabGravity="center"
                app:tabMode="scrollable" />

        </RelativeLayout>

    </androidx.cardview.widget.CardView>
    <include layout="@layout/layout_fab_chat" />
</RelativeLayout>